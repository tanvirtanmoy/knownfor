# Supabase project URL — found in Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY. Never expose to the browser.
# Used for admin moderation actions and seeding.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL used for canonical links, Open Graph and redirects.
NEXT_PUBLIC_SITE_URL=https://knownfor.eu

# --- Optional: AI summaries (lib/ai/summarize-feedback.ts) ---
# If unset, a deterministic local heuristic is used instead.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Optional: email notifications on new feedback (Resend) ---
# If any of these are unset, notifications are silently skipped.
RESEND_API_KEY=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=KnownFor <noreply@knownfor.eu>
